# Backend service config (root .env)
# 复制为 .env 后按需修改；生产请用部署平台注入环境变量

# 后端端口
PORT=3001

# IMAP 基础配置
EMAIL_HOST="imap.example.com"
EMAIL_PORT=993
EMAIL_USER="user@example.com"
# 建议使用邮箱“客户端授权码”，不要填登录密码
EMAIL_PASS="your-app-password"
EMAIL_TLS=true

# 邮件标题过滤正则（字符串）；留空表示不过滤
EMAIL_TITLE_REGEX="Error|Warning|Alert"

# 提示：前端访问门禁 key 使用 VITE_ACCESS_KEY（见 frontend/.env.local）

