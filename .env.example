# ===== 服务端 =====
SERVER_PORT=3001

# ===== IMAP =====
IMAP_HOST="imap.example.com"
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER="user@example.com"
EMAIL_PASS=""

# ===== 访问会话 =====
FRONTEND_KEY=""
SESSION_COOKIE_NAME="mw_sid"
SESSION_TTL_MS=300000

# ===== 过滤规则 =====
# 主题命中任一关键词（逗号分隔）
WHITELIST="验证码,code,verify"
# 发件人域名后缀白名单
MAIL_FROM_DOMAIN_SUFFIX_WHITELIST="abc.com"

# ===== 展示限制（可选） =====
MAIL_LIST_LIMIT=20
MAIL_SOURCE_MAX_CHARS=200000

# ===== 限流（可选） =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_SSR=30
RATE_LIMIT_SSE=60

# ===== 日志（可选） =====
PERF_LOG=false
