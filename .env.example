## 环境变量：包含非敏感配置与敏感项

# 服务端
SERVER_PORT=3001

# 邮箱连接（非敏感项）
IMAP_HOST="imap.example.com"
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER="user@example.com"

# 会话
SESSION_COOKIE_NAME="mw_sid"
SESSION_TTL_MS=300000

# 限流（按来源地址）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_API=60
RATE_LIMIT_SSR=30

# 邮箱“客户端授权码”或密码（必填）
EMAIL_PASS=""

# 访问密钥（必填，用于首次登录创建会话）
FRONTEND_KEY=""

# 模型验证码提取（兼容接口）
AI_BASE_URL="https://api.deepseek.com"
AI_API_KEY=""
AI_MODEL="deepseek-chat"
AI_PROMPT="输入是单封邮件的 JSON，包含 uid/subject/date。请输出 JSON 对象，格式：{\"time\":\"<date>\",\"code\":\"<code>\"}。若未找到验证码，返回空 JSON 对象 {}。如果是密码重置类邮件（password reset / reset code），必须返回空 JSON 对象 {}。必须从 subject 中提取验证码。"
AI_TIMEOUT_MS=15000
AI_LOG=false
PERF_LOG=false
AI_MAX_TOKENS=64
AI_PAYLOAD_MAX=800
AI_DISABLE_CACHE=true
AI_SUBJECT_WHITELIST="验证码,ChatGPT,code,verify"
